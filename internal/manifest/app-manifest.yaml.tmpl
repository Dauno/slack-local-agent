# The app-level Socket Mode token is created manually with connections:write.
display_information:
  name: {{ quote .AppName }}
features:
  bot_user:
    display_name: {{ quote .BotDisplayName }}
    always_online: false
oauth_config:
  scopes:
    bot:
      - app_mentions:read
      - channels:history
      - channels:read
      - chat:write
      - files:read
      - groups:history
      - groups:read
      - im:history
      - im:write
      - users:read
settings:
  interactivity:
    is_enabled: true
  event_subscriptions:
    bot_events:
      - app_mention
      - message.channels
      - message.groups
      - message.im
  org_deploy_enabled: false
  socket_mode_enabled: true
  token_rotation_enabled: false
